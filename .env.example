## OpenAI-compatible API (optional, for llm scripts)
# OPENAI_API_KEY=your_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

## Qianfan (optional, for ERNIE via qianfan sdk)
# QIANFAN_ACCESS_KEY=your_key_here
# QIANFAN_SECRET_KEY=your_key_here

## Data path overrides (optional)
# COGECI_DATA_DIR=./data
# COGECI_ESL_XML_ROOT=./data/v0.9
